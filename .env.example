# Copy to `.env.local` and fill in. All are optional for local development.

# Public site URL — used for canonical links, sitemap, and Open Graph.
NEXT_PUBLIC_SITE_URL="https://enzohrrr.github.io"

# Web3Forms access key — enables the contact form to send real email.
# Get a free key (no account) at https://web3forms.com — enter your email,
# receive the key. It is a PUBLIC key by design (safe to expose in the build).
# Without it, the contact form points visitors to your email instead.
NEXT_PUBLIC_WEB3FORMS_KEY=""
